@page "/"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService

<PageTitle>Home</PageTitle>

<h1 style="color: white;"> space space </h1>

<h1> Top Players: </h1>

<h3 style="color: white;"> space space </h3>

<div class="players-container">

    @for (int i = 0; i < players.Count; i++)
    {
        <div class="player-card">

            <div class="player-header">
                <img src="@players[i].ImageUrl" class="player-img">

                <div class="player-text">
                    <h2>@players[i].Name</h2>
                    <p class="team">@players[i].TeamName</p>
                </div>
            </div>

            <div class="player-stats">
                <p>Points Per Game: @players[i].PPG</p>
                <p>Assist Per Game: @players[i].APG</p>
                <p>Rebounds Per Game: @players[i].RPG</p>
            </div>

        </div>
    }
</div>

<h1 style="color: white;"> space space </h1>

<h1> All NBA Team: @teams.Count </h1>

<h3 style="color: white;"> space space </h3>

<div class="teams-container">

    @for (int i = 0; i < teams.Count; i++)
    {
        <div class="team-card">
            <img src="@teams[i].LogoUrl" />
            <p> @teams[i].TeamName </p>
        </div>
    }

</div>


@code {
    private string search = "";

    private List<Player> players = new List<Player>();
    private List<Teams> teams = new List<Teams>();
    private List<Search> result = new List<Search>();

    protected override void OnInitialized()
    {
        players = UserService.GetFeaturedPlayers();
        teams = UserService.GetAllTeams();

        Console.WriteLine($"Loaded {teams.Count} teams");
    }


    void DoSearch()
    {
        result = UserService.Search(search);

        Console.WriteLine($"Search for '{search}' returned {result.Count} results");
    }

    void Login()
    {

    }

    void Register()
    {

    }
}

<style>

    .teams-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        /* fit as many as possible per row */
        gap: 10px;
        width: 100%;
        max-width: 1200px;
        /* optional: limits total width */
        margin: 0 auto;
        /* center on page */
        padding: 10px;
    }

    .team-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #e3e3e3;
        border: 1px solid black;
        border-radius: 5px;
        padding: 5px;
        text-align: center;
    }

    .team-card img {
        width: 50px;
        height: 50px;
        object-fit: contain;
        margin-bottom: 5px;
    }

    .team-card p {
        font-size: 10px;
        /* small but readable */
        margin: 0;
    }

    .players-container {
        display: flex;
        flex-wrap: wrap;
        /* allows multiple rows if needed */
        gap: 20px;
        /* spacing between cards */
        justify-content: center;
        /* center the row of cards */
    }

    .player-card {
        width: 300px;
        /* smaller width */
        background: #e3e3e3;
        border: 3px solid black;
        padding: 15px;
        /* smaller padding */
        margin: 0;
    }

    .player-img {
        width: 120px;
        /* smaller image to fit card */
    }

    .player-text h2 {
        font-size: 28px;
        /* smaller title */
    }

    .player-stats p {
        font-size: 20px;
        /* smaller stats text */
    }

    .player-header {
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .team {
        font-size: 18px;
        color: #444;
        margin-top: 8px;
    }
</style>