@page "/"
@using Project.Data
@inject UserService UserService

<PageTitle>Home</PageTitle>

<div class="topbar">

    <div class="name">
        NBA Stats 
        <img src="images/NBA.png"/>
    </div>
    
    <div class="search">
        <input @bind="search" type="text" placeholder="Search for a Player or a Team... "/>
        <button class="btn btn-primary" @onclick="DoSearch"> Search </button>
    </div>
    
     <div class="sign">
         <button class="btn btn-primary" @onclick="Login"> Login </button>
        <button class="btn btn-primary" @onclick="Register"> Register </button>
     </div>
</div>

<div class="menu">
    <div class="menu-container">

        <div class="menu-item">
            <a href="/"> Home </a>
        </div>

        <div class="menu-item">
            <a href="/players"> Players </a>
        </div>

        <div class="menu-item">
            <a href="/teams"> Teams </a>
        </div>

        <div class="menu-item">
            <a href="/build"> Build a Team </a>
        </div>

        <div class="menu-item">
            <a href="/favorites"> Favorites </a>
        </div>

    </div>
</div>

<h1 style="color: white;"> space space </h1>

<h1> Top Players: </h1>

<h3 style="color: white;"> space space </h3>

<div class="players-container">

    @for (int i = 0; i < players.Count; i++)
    {
        <div class="player-card">

            <div class="player-header">
                <img src="@players[i].ImageUrl" class="player-img">

                <div class="player-text">
                    <h2>@players[i].Name</h2>
                    <p class="team">@players[i].TeamName</p>
                </div>
            </div>

            <div class="player-stats">
                <p>Points Per Game: @players[i].PPG</p>
                <p>Assist Per Game: @players[i].APG</p>
                <p>Rebounds Per Game: @players[i].RPG</p>
            </div>

        </div>
    }

</div>

<h1 style="color: white;"> space space </h1>

<h1> All NBA Team: @teams.Count </h1>

<h3 style="color: white;"> space space </h3>

<div class="teams-container">

    @for (int i = 0; i < teams.Count; i++)
    {
        <div class="team-card">
            <img src="@teams[i].LogoUrl" />
            <p> @teams[i].Name </p>
        </div>
    }

</div>


@code {
    private string search = "";

    private List<Player> players = new List<Player>();
    private List<Teams> teams = new List<Teams>();

    protected override void OnInitialized()
    {
        players = UserService.GetFeaturedPlayers();
        teams = UserService.GetAllTeams();

        Console.WriteLine($"Loaded {teams.Count} teams");
    }


    void DoSearch()
    {

    }

    void Login()
    {

    }

    void Register()
    {
        
    }
}

<style>

    .teams-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr)); /* fit as many as possible per row */
        gap: 10px;
        width: 100%;
        max-width: 1200px; /* optional: limits total width */
        margin: 0 auto; /* center on page */
        padding: 10px;
    }

    .team-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #e3e3e3;
        border: 1px solid black;
        border-radius: 5px;
        padding: 5px;
        text-align: center;
    }

        .team-card img {
            width: 50px;
            height: 50px;
            object-fit: contain;
            margin-bottom: 5px;
        }

        .team-card p {
            font-size: 10px; /* small but readable */
            margin: 0;
        }

    .players-container {
        display: flex;
        flex-wrap: wrap; /* allows multiple rows if needed */
        gap: 20px; /* spacing between cards */
        justify-content: center; /* center the row of cards */
    }

    .player-card {
        width: 300px; /* smaller width */
        background: #e3e3e3;
        border: 3px solid black;
        padding: 15px; /* smaller padding */
        margin: 0;
    }

    .player-img {
        width: 120px; /* smaller image to fit card */
    }

    .player-text h2 {
        font-size: 28px; /* smaller title */
    }

    .player-stats p {
        font-size: 20px; /* smaller stats text */
    }

    .player-header {
        display: flex;
        align-items: center;
        gap: 25px;
    }


   

    .team {
        font-size: 18px;
        color: #444;
        margin-top: 8px;
    }

  

    /* --- Top Bar --- */
    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 20px;
        border: 1px solid black;
        width: 100%;
        box-sizing: border-box;
        background-color: #f8f9fa;
    }

        .topbar .name {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: bold;
        }

            .topbar .name img {
                height: 30px;
            }

        .topbar .search {
            display: flex;
            flex: 1;
            gap: 5px;
            align-items: center;
            max-width: 500px;
        }

            .topbar .search input {
                flex: 1;
                padding: 6px 10px;
                font-size: 16px;
            }

            .topbar .search button {
                white-space: nowrap;
            }

        .topbar .sign {
            display: flex;
            gap: 5px;
        }

   .menu {
    padding: 0; 
    margin: 0 auto;
    background-color: #e9ecef;
    border-left: 1px solid black;
    border-right: 1px solid black;
    border-bottom: 1px solid black;
}

.menu-container {
    display: flex;           /* horizontal layout */
    gap: 10px;               /* space between boxes */
    justify-content: center;  /* center menu items */
    padding: 5px 0;           /* vertical padding */
}

.menu-item {
    border: 1px solid black;   /* box border */
    border-radius: 4px;
    background-color: #fff;
    padding: 5px 10px;
    text-align: center;
    display: flex;             /* makes the fill the box */
    align-items: center;
    justify-content: center;
}

.menu-item a {
    text-decoration: none;
    color: black;
    font-weight: bold;
    display: block;           /* fill the .menu-item box */
    width: 100%;
}

.menu-item:hover {
    background-color: #d0d0d0;
    cursor: pointer;
}

     
</style>