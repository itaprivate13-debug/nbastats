@page "/players"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject NavigationManager Nav

<div class="header-container">

    <h1> All NBA Players: </h1>

    <div class="sort-bar">

        <p> Sort By: </p>
        <button class="btn btn-secondary" @onclick="(() => SortByPPG())"> PPG </button>
        <button class="btn btn-secondary" @onclick="(() => SortByAPG())"> APG </button>
        <button class="btn btn-secondary" @onclick="(() => SortByRPG())"> RPG </button>
    </div>

</div>


<hr />

<div class="players-container">

    @foreach (var players in players)
    {
        <div class="player-card" @onclick="(() => GoToPlayer(players.Id))">

            <div class="player-header">
                <img src="@players.ImageUrl" class="player-img">

                <div class="player-text">
                    <h2>@players.Name</h2>
                    <p class="team">@players.TeamName</p>
                </div>
            </div>

            <div class="player-stats">
                <p>Points Per Game: @players.PPG</p>
                <p>Assist Per Game: @players.APG</p>
                <p>Rebounds Per Game: @players.RPG</p>
            </div>

        </div>
    }
</div>

@code {
    private List<Player> players = new List<Player>();

    protected override void OnInitialized()
    {
        players = UserService.GetAllPlayers();
    }

    void GoToPlayer(int id)
    {
        Nav.NavigateTo($"/player/{id}");
    }

    void SortByPPG()
    {
        players = UserService.SortByPPG(players);
    }

    void SortByAPG()
    {
        players = UserService.SortByAPG(players);
    }

    void SortByRPG()
    {
        players = UserService.SortByRPG(players);
    }
}

<style>

    .player-card:hover {
        background-color: #e9ecef; /* light gray on hover */
        transform: scale(1.02); /* tiny zoom effect */
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .header-container {
        display: flex;
        align-items: center;
        gap: 20px; /* space between h1 and sort buttons */
        flex-wrap: wrap; /* optional, allows wrapping on small screens */
    }

        .header-container h1 {
            margin: 0;
        }

    .sort-bar {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .sort-bar p {
            margin: 0;
        }

    .players-container {
        display: flex;
        flex-wrap: wrap;
        /* allows multiple rows if needed */
        gap: 20px;
        /* spacing between cards */
        justify-content: center;
        /* center the row of cards */
    }

    .player-card {
        width: 300px;
        /* smaller width */
        background: #e3e3e3;
        border: 3px solid black;
        padding: 15px;
        /* smaller padding */
        margin: 0;
    }

    .player-img {
        width: 120px;
        /* smaller image to fit card */
    }

    .player-text h2 {
        font-size: 28px;
        /* smaller title */
    }

    .player-stats p {
        font-size: 20px;
        /* smaller stats text */
    }

    .player-header {
        display: flex;
        align-items: center;
        gap: 25px;
    }

</style>