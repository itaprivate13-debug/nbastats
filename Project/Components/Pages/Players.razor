@page "/players"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService

<h1> All NBA Players: </h1>

<hr />

<div class="players-container">

    @for (int i = 0; i < players.Count; i++)
    {
        <div class="player-card">

            <div class="player-header">
                <img src="@players[i].ImageUrl" class="player-img">

                <div class="player-text">
                    <h2>@players[i].Name</h2>
                    <p class="team">@players[i].TeamName</p>
                </div>
            </div>

            <div class="player-stats">
                <p>Points Per Game: @players[i].PPG</p>
                <p>Assist Per Game: @players[i].APG</p>
                <p>Rebounds Per Game: @players[i].RPG</p>
            </div>

        </div>
    }
</div>

@code {
    private List<Player> players = new List<Player>();

    protected override void OnInitialized()
    {
        players = UserService.GetAllPlayers();
    }
}

<style>
    .players-container {
        display: flex;
        flex-wrap: wrap;
        /* allows multiple rows if needed */
        gap: 20px;
        /* spacing between cards */
        justify-content: center;
        /* center the row of cards */
    }

    .player-card {
        width: 300px;
        /* smaller width */
        background: #e3e3e3;
        border: 3px solid black;
        padding: 15px;
        /* smaller padding */
        margin: 0;
    }

    .player-img {
        width: 120px;
        /* smaller image to fit card */
    }

    .player-text h2 {
        font-size: 28px;
        /* smaller title */
    }

    .player-stats p {
        font-size: 20px;
        /* smaller stats text */
    }

    .player-header {
        display: flex;
        align-items: center;
        gap: 25px;
    }
</style>